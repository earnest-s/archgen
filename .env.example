# Browser-facing frontend API endpoint (build-time for Vite frontend image)
VITE_API_URL=http://localhost:8000

# Model runtime controls
# Set to false to fail fast when GPU is unavailable (no mock/fallback responses).
MODEL_ALLOW_FALLBACK=true

# Docker Compose GPU request for model service (usually 'all').
MODEL_GPUS=all

# NVIDIA runtime variables for GPU containers.
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Backend CORS allow-list (comma-separated)
FRONTEND_ORIGIN=http://localhost:5173

# Backend -> model internal URL
MODEL_URL=http://model:9000
